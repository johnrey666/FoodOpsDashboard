<Window x:Class="FoodOpsDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LFR 2026 — Food Operations Dashboard"
        Height="920" Width="1440" MinHeight="700" MinWidth="1100"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Grid>
    <DockPanel>

        <!-- Header with title + nav -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="7" Background="{StaticResource AccentBrush}" Margin="0,0,10,0">
                        <TextBlock Text="L" Foreground="White" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="LFR Food Ops" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="2026" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="8,0,16,0"/>

                    <Border Background="#F1F5F9" CornerRadius="8" Padding="3" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="NavDashboard" Content="Dashboard" GroupName="MainNav"
                                         Style="{StaticResource NavRadioStyle}" IsChecked="True"
                                         Checked="OnNavChanged"/>
                            <RadioButton x:Name="NavDataEntry" Content="Data Entry" GroupName="MainNav"
                                         Style="{StaticResource NavRadioStyle}"
                                         Checked="OnNavChanged"/>
                            <RadioButton x:Name="NavStoreList" Content="Store List" GroupName="MainNav"
                                         Style="{StaticResource NavRadioStyle}"
                                         Checked="OnNavChanged"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="StatusText" Text=""
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" VerticalAlignment="Center"
                               MaxWidth="320" TextTrimming="CharacterEllipsis"
                               Margin="0,0,14,0"/>
                    <TextBlock Text="How to Use"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Cursor="Hand"
                               TextDecorations="Underline"
                               MouseLeftButtonUp="OnHowToUseClick"
                               ToolTip="Open the user guide"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="24,16,24,20">

            <!-- ===================== DASHBOARD ===================== -->
            <Grid x:Name="DashboardView">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filters -->
                <Border Grid.Row="0" Style="{StaticResource SurfaceStyle}" Padding="12,10" Margin="0,0,0,12">
                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                            <TextBlock Text="Year" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="YearCombo" Style="{StaticResource ComboStyle}" Width="90"
                                      SelectionChanged="OnFilterChanged" Margin="0,0,16,0"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Store" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="StoreCombo" Style="{StaticResource ComboStyle}" Width="180"
                                      SelectionChanged="OnFilterChanged"
                                      VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Months" Style="{StaticResource FieldLabelStyle}"
                                       VerticalAlignment="Center"/>
                            <WrapPanel x:Name="MonthCheckPanel" VerticalAlignment="Center"/>
                            <Button Content="All" Style="{StaticResource SecondaryButtonStyle}" Padding="10,5"
                                    Click="OnSelectAllMonths" Margin="6,0,6,0"
                                    VerticalAlignment="Center"/>
                            <Button Content="Clear" Style="{StaticResource SecondaryButtonStyle}" Padding="10,5"
                                    Click="OnClearMonths"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </WrapPanel>
                </Border>

                <!-- Key financial metrics — matches Computation Sheet set -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="Key financial metrics" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="2,0,0,8"/>
                    <UniformGrid x:Name="KpiPanel" Columns="7"/>
                </StackPanel>

                <!-- Chart + Top 5 expenses -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfaceStyle}" Padding="14">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="Monthly sales trend" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource TySeriesBrush}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="TY" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,10,0"/>
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource TgtSeriesBrush}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="TGT" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,10,0"/>
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource LySeriesBrush}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="LY" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </DockPanel>
                            <Canvas x:Name="TrendCanvas" Height="220" Background="Transparent"
                                    SizeChanged="OnTrendCanvasSizeChanged"/>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SurfaceStyle}" Padding="14">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Top 5 operating expenses"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <DataGrid x:Name="ExpenseGrid" Style="{StaticResource AppDataGridStyle}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="EXPENSE" Binding="{Binding Expense}" Width="1.7*"/>
                                    <DataGridTextColumn Header="TY" Binding="{Binding TY, StringFormat={}{0:#,##0}}" Width="*"/>
                                    <DataGridTextColumn Header="% UTIL" Binding="{Binding UtilizationPct, StringFormat={}{0:0.0%}}" Width="0.85*"/>
                                    <DataGridTextColumn Header="% OPEX" Binding="{Binding PctOfTotalOpex, StringFormat={}{0:0.0%}}" Width="0.8*"/>
                                    <DataGridTextColumn Header="% SALES" Binding="{Binding PctOfTotalSales, StringFormat={}{0:0.0%}}" Width="0.8*"/>
                                    <DataGridTextColumn Header="VS LY" Binding="{Binding GrowthPct, StringFormat={}{0:+0.0%;-0.0%}}" Width="0.8*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===================== DATA ENTRY ===================== -->
            <DockPanel x:Name="DataEntryView" Visibility="Collapsed">
                <Border DockPanel.Dock="Top" Style="{StaticResource SurfaceStyle}" Padding="16,14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Data table" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Style="{StaticResource HintStyle}" Margin="0,0,0,12"
                                   Text="Enter TY and TGT for the selected year. LY is auto from last year’s TY. Export / Import supports DATA xlsx or FO MPT workbooks (group sheets with month columns)."/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Year" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="DataYearCombo" Style="{StaticResource ComboStyle}" Width="100"
                                      SelectionChanged="OnDataFilterChanged" Margin="0,0,16,0"/>
                            <TextBlock Text="Month" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="DataMonthCombo" Style="{StaticResource ComboStyle}"
                                      SelectionChanged="OnDataFilterChanged" Margin="0,0,16,0"/>
                            <TextBlock Text="Store" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="DataStoreCombo" Style="{StaticResource ComboStyle}" Width="180"
                                      SelectionChanged="OnDataFilterChanged" Margin="0,0,16,0"/>
                            <Button Content="Export xlsx" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="OnExportExcelClick" Margin="0,0,8,0"/>
                            <Button Content="Import xlsx" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="OnImportExcelClick" Margin="0,0,8,0"/>
                            <Button Content="Reset" Style="{StaticResource DangerButtonStyle}"
                                    Click="OnResetDataClick" Margin="0,0,12,0"/>
                            <TextBlock x:Name="DataRowCountText" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SurfaceStyle}" Padding="8">
                    <DataGrid x:Name="DataEntryGrid"
                              Style="{StaticResource AppDataGridStyle}"
                              AutoGenerateColumns="False"
                              CanUserDeleteRows="False"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              PreparingCellForEdit="OnDataEntryPreparingCellForEdit"
                              CellEditEnding="OnDataEntryCellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Month" Binding="{Binding Month}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Store" Binding="{Binding Store}" Width="140" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Account" Binding="{Binding Account}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="TY" Binding="{Binding TY, UpdateSourceTrigger=LostFocus}" Width="*"/>
                            <DataGridTextColumn Header="TGT" Binding="{Binding TGT, UpdateSourceTrigger=LostFocus}" Width="*"/>
                            <DataGridTextColumn Header="LY (auto)" Binding="{Binding LY, StringFormat={}{0:#,##0.##}}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </DockPanel>

            <!-- ===================== STORE LIST ===================== -->
            <DockPanel x:Name="StoreListView" Visibility="Collapsed">
                <Border DockPanel.Dock="Top" Style="{StaticResource SurfaceStyle}" Padding="16,14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Store list" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Style="{StaticResource HintStyle}" Margin="0,0,0,12"
                                   Text="Add a store to create blank DATA rows for every year × month × account."/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NewStoreNameBox" Style="{StaticResource FieldBoxStyle}"
                                     Width="180" Margin="0,0,12,0"/>
                            <TextBlock Text="Group" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NewStoreGroupBox" Style="{StaticResource FieldBoxStyle}"
                                     Width="120" Margin="0,0,12,0"/>
                            <Button Content="Add" Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OnAddStoreClick" Margin="0,0,8,0"/>
                            <Button Content="Remove" Style="{StaticResource DangerButtonStyle}"
                                    Click="OnRemoveStoreClick"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SurfaceStyle}" Padding="8">
                    <DataGrid x:Name="StoreGrid"
                              Style="{StaticResource AppDataGridStyle}"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              BeginningEdit="OnStoreBeginningEdit"
                              CellEditEnding="OnStoreCellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Store Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridTextColumn Header="Group" Binding="{Binding Group, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </DockPanel>

        </Grid>
    </DockPanel>

        <!-- KPI breakdown modal — flies + flips from the clicked card -->
        <Grid x:Name="MetricDetailOverlay" Visibility="Collapsed" Panel.ZIndex="100">
            <Border x:Name="MetricDetailScrim" Background="#8A0F172A" Opacity="0"
                    MouseLeftButtonDown="OnMetricDetailScrimClick"/>
            <Canvas x:Name="MetricDetailStage">
                <Border x:Name="MetricDetailModal"
                        Background="White" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="14" ClipToBounds="True"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <!-- Local Y-flip: ScaleX = |cos(angle)| -->
                            <ScaleTransform x:Name="MetricDetailFlip" ScaleX="1" ScaleY="1"/>
                            <!-- Fly + grow from card → center -->
                            <ScaleTransform x:Name="MetricDetailGrow" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="MetricDetailMove"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.22" Color="#0F172A"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Face A: looks like the KPI card -->
                        <Border x:Name="MetricDetailFront" Background="White" Padding="12">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="MetricDetailFrontTitle" FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="MetricDetailFrontAmount" FontSize="20"
                                           FontWeight="Bold" Margin="0,6,0,0"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Face B: infographic breakdown -->
                        <Border x:Name="MetricDetailBack" Visibility="Collapsed">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#F0F9FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <DockPanel Margin="16">
                                <!-- Header -->
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Content="✕" Padding="8,2"
                                            VerticalAlignment="Top"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="OnCloseMetricDetailClick"/>
                                    <StackPanel>
                                        <TextBlock Text="BREAKDOWN" FontSize="9" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Margin="0,0,0,3"/>
                                        <TextBlock x:Name="MetricDetailTitle" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <Border Background="#E0F2FE" CornerRadius="6" Padding="8,4"
                                                Margin="0,8,12,0" HorizontalAlignment="Left">
                                            <TextBlock x:Name="MetricDetailFormula" FontSize="11"
                                                       TextWrapping="Wrap" FontWeight="SemiBold"
                                                       Foreground="#0369A1"/>
                                        </Border>
                                    </StackPanel>
                                </DockPanel>

                                <!-- Snapshot tiles -->
                                <UniformGrid DockPanel.Dock="Top" Columns="5" Margin="0,0,0,12">
                                    <Border Style="{StaticResource MetricTileStyle}" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="THIS YEAR" Style="{StaticResource MetricTileLabelStyle}"/>
                                            <TextBlock x:Name="MetricDetailTy" Style="{StaticResource MetricTileValueStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricTileStyle}" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="TARGET" Style="{StaticResource MetricTileLabelStyle}"/>
                                            <TextBlock x:Name="MetricDetailTgt" Style="{StaticResource MetricTileValueStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricTileStyle}" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="LAST YEAR" Style="{StaticResource MetricTileLabelStyle}"/>
                                            <TextBlock x:Name="MetricDetailLy" Style="{StaticResource MetricTileValueStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricTileStyle}" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="% OF SALES" Style="{StaticResource MetricTileLabelStyle}"/>
                                            <TextBlock x:Name="MetricDetailPctSales" Style="{StaticResource MetricTileValueStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Text="GROWTH" Style="{StaticResource MetricTileLabelStyle}"/>
                                            <TextBlock x:Name="MetricDetailGr" Style="{StaticResource MetricTileValueStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <!-- Composition header -->
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <TextBlock Text="Composition" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right" x:Name="MetricDetailRowCount"
                                               FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </DockPanel>

                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="MetricDetailCompositionPanel"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
            </Canvas>
        </Grid>

        <!-- How to Use — user guide modal -->
        <Grid x:Name="HowToUseOverlay" Visibility="Collapsed" Panel.ZIndex="110">
            <Border Background="#8A0F172A" MouseLeftButtonDown="OnHowToUseScrimClick"/>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="740" MaxHeight="680" Margin="24"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="14" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F0F9FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.22" Color="#0F172A"/>
                </Border.Effect>
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Padding="22,18,16,16"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#E0F2FE" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="✕" Padding="8,2"
                                    VerticalAlignment="Top" Margin="8,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="OnCloseHowToUseClick"/>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0"
                                        Background="{StaticResource AccentBrush}"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="?" Foreground="White" FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="USER GUIDE" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="How to Use" FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Dashboard · Data Entry · Store List · Metrics"
                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Footer -->
                    <Border DockPanel.Dock="Bottom" Background="White"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Padding="22,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="Press Esc to close"
                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Content="Got it" Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Right" Padding="20,8"
                                    Click="OnCloseHowToUseClick"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,16,14,12">
                        <StackPanel Margin="0,0,8,4">

                            <!-- Getting started -->
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="22" Height="22" CornerRadius="6" Background="#E0F2FE" Margin="0,0,8,0">
                                            <TextBlock Text="1" FontSize="11" FontWeight="Bold" Foreground="#0369A1"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Getting started" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap" LineHeight="19"
                                               Text="Use the header tabs to switch views. Edits auto-save — watch the status text in the top-right."/>
                                    <UniformGrid Columns="3" Margin="0,12,0,0">
                                        <Border Background="#F0F9FF" CornerRadius="8" Padding="10,8" Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="Dashboard" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                                <TextBlock Text="KPIs &amp; charts" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#F0F9FF" CornerRadius="8" Padding="10,8" Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="Data Entry" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                                <TextBlock Text="Enter TY &amp; TGT" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#F0F9FF" CornerRadius="8" Padding="10,8">
                                            <StackPanel>
                                                <TextBlock Text="Store List" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                                <TextBlock Text="Manage stores" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <!-- Dashboard -->
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="22" Height="22" CornerRadius="6" Background="#E0F2FE" Margin="0,0,8,0">
                                            <TextBlock Text="2" FontSize="11" FontWeight="Bold" Foreground="#0369A1"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Dashboard" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,7">
                                            <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                     Margin="2,6,10,0" VerticalAlignment="Top"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap" LineHeight="18"
                                                       Text="Pick Year, Store, and one or more Months (All / Clear). Multi-month selection consolidates totals."/>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,7">
                                            <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                     Margin="2,6,10,0" VerticalAlignment="Top"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap" LineHeight="18"
                                                       Text="KPI cards: Sales, Cost of Sales, Gross Profit, Total OPEX, SBU CM, SBU EBITDA, Net Income."/>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,7">
                                            <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                     Margin="2,6,10,0" VerticalAlignment="Top"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap" LineHeight="18"
                                                       Text="Each card shows GR, vs TGT, and vs LY. Some also show % of sales."/>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,7">
                                            <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                     Margin="2,6,10,0" VerticalAlignment="Top"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap" LineHeight="18"
                                                       Text="Click Total OPEX or SBU EBITDA for a breakdown of account composition."/>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,7">
                                            <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                     Margin="2,6,10,0" VerticalAlignment="Top"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap" LineHeight="18"
                                                       Text="Monthly sales trend always shows all 12 months (month filter is ignored on the chart)."/>
                                        </DockPanel>
                                        <DockPanel>
                                            <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                     Margin="2,6,10,0" VerticalAlignment="Top"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap" LineHeight="18"
                                                       Text="Top 5 operating expenses ranked by |TY|, with % UTIL, % OPEX, % SALES, and VS LY."/>
                                        </DockPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Data Entry -->
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="22" Height="22" CornerRadius="6" Background="#E0F2FE" Margin="0,0,8,0">
                                            <TextBlock Text="3" FontSize="11" FontWeight="Bold" Foreground="#0369A1"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Data Entry" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <DockPanel Margin="0,0,0,7">
                                        <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                 Margin="2,6,10,0" VerticalAlignment="Top"/>
                                        <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" LineHeight="18"
                                                   Text="Filter by Year, Month, and Store. Enter TY (this year) and TGT (target) only."/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,7">
                                        <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                 Margin="2,6,10,0" VerticalAlignment="Top"/>
                                        <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" LineHeight="18"
                                                   Text="LY is automatic — last year’s TY for the same Month / Store / Account (e.g. 2026 → LY from 2025)."/>
                                    </DockPanel>
                                    <DockPanel>
                                        <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                 Margin="2,6,10,0" VerticalAlignment="Top"/>
                                        <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" LineHeight="18"
                                                   Text="Export / Import xlsx: DATA + Stores format, or FO MPT workbook (e.g. JUNE 2026_FO1 MPT per Format.xlsx). Reset clears all TY/TGT after confirmation. No Save button needed."/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- Store List -->
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="22" Height="22" CornerRadius="6" Background="#E0F2FE" Margin="0,0,8,0">
                                            <TextBlock Text="4" FontSize="11" FontWeight="Bold" Foreground="#0369A1"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Store List" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <DockPanel Margin="0,0,0,7">
                                        <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                 Margin="2,6,10,0" VerticalAlignment="Top"/>
                                        <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" LineHeight="18"
                                                   Text="Add a store (name + optional group) to create blank DATA rows for every year × month × account."/>
                                    </DockPanel>
                                    <DockPanel>
                                        <Ellipse DockPanel.Dock="Left" Width="6" Height="6" Fill="{StaticResource AccentBrush}"
                                                 Margin="2,6,10,0" VerticalAlignment="Top"/>
                                        <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" LineHeight="18"
                                                   Text="Rename or change Group in the grid. Remove deletes the selected store and its data rows."/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- Metrics -->
                            <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="22" Height="22" CornerRadius="6" Background="#E0F2FE" Margin="0,0,8,0">
                                            <TextBlock Text="5" FontSize="11" FontWeight="Bold" Foreground="#0369A1"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="How metrics are calculated" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,10"
                                               Text="All KPIs come from Data Entry detail accounts for the selected Year, Month(s), and Store. LY uses the same formula on prior-year TY."/>

                                    <Border Background="#F8FAFC" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                        <TextBlock FontSize="11.5" Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" LineHeight="17"
                                                   Text="Sales = Σ Sales    ·    Cost of Sales = Σ Cost of Sales    ·    Gross Profit = Sales − Cost of Sales + Miscellaneous Income"/>
                                    </Border>
                                    <Border Background="#F8FAFC" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                        <TextBlock FontSize="11.5" Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" LineHeight="17"
                                                   Text="Total OPEX = store operating expenses (excludes HO, Corp &amp; EO, Interest, GOC)"/>
                                    </Border>
                                    <Border Background="#F8FAFC" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                        <TextBlock FontSize="11.5" Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" LineHeight="17"
                                                   Text="SBU CM = Gross Profit − Total OPEX − HO    ·    SBU EBITDA = SBU CM + Depreciation + Amortization + HO DA"/>
                                    </Border>
                                    <Border Background="#F8FAFC" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                        <TextBlock FontSize="11.5" Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" LineHeight="17"
                                                   Text="Net Income = SBU CM − Corp &amp; EO Share − Interest Expense − GOC Expenses"/>
                                    </Border>
                                    <WrapPanel Margin="0,4,0,0">
                                        <Border Background="#E0F2FE" CornerRadius="6" Padding="8,4" Margin="0,0,6,6">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#0369A1"
                                                       Text="GR / vs LY = (TY − LY) / |LY|"/>
                                        </Border>
                                        <Border Background="#E0F2FE" CornerRadius="6" Padding="8,4" Margin="0,0,6,6">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#0369A1"
                                                       Text="vs TGT = (TY − TGT) / |TGT|"/>
                                        </Border>
                                        <Border Background="#E0F2FE" CornerRadius="6" Padding="8,4" Margin="0,0,0,6">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#0369A1"
                                                       Text="% of sales = TY ÷ Sales TY"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Tip callout -->
                            <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                    CornerRadius="10" Padding="14,12">
                                <DockPanel>
                                    <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="8"
                                            Background="#F59E0B" Margin="0,0,12,0" VerticalAlignment="Top">
                                        <TextBlock Text="!" Foreground="White" FontSize="14" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Reset with confirmation" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#92400E" Margin="0,0,0,3"/>
                                        <TextBlock FontSize="12" Foreground="#A16207"
                                                   TextWrapping="Wrap" LineHeight="18"
                                                   Text="On Data Entry, use Reset to clear all TY and TGT values across every year, month, store, and account. You will be asked to confirm before any data is wiped."/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
