<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>FoodOpsDashboard</RootNamespace>
    <AssemblyName>FoodOpsDashboard</AssemblyName>
    <ApplicationIcon></ApplicationIcon>
    <!-- No NuGet packages are referenced, so this project builds and runs
         completely offline once the .NET 8 SDK is installed. -->
  </PropertyGroup>

</Project>